# Database
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Admin credentials (used to seed the admin user)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-secure-password-here"

# JWT Secret (generate a random 64-char hex string)
JWT_SECRET="your-jwt-secret-here"

# IntaSend Payment Gateway
INTASEND_PUBLISHABLE_KEY="ISPubKey_test_xxx"
INTASEND_SECRET_KEY="ISSecretKey_test_xxx"
INTASEND_TEST=true

# Resend Email API
RESEND_API_KEY="re_xxxxx"
EMAIL_FROM="noreply@yourdomain.com"

# Vercel (for file uploads via Vercel Blob)
VERCEL_TOKEN=""
VERCEL_TEAM_ID=""

# Site URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
